# ─── Server ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Required in production — server will not start without this
SESSION_SECRET=your-random-secret-here

# Directory for SQLite database files and backups
DATA_DIR=/data

# ─── Admin Credentials ──────────────────────────────────────────
# Override default admin credentials (strongly recommended for production)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me-in-production
SUPER_ADMIN_DISPLAY_NAME=Super Admin

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
ADMIN_DISPLAY_NAME=Admin

# ─── Encryption ─────────────────────────────────────────────────
# Optional — if not set, derived from SESSION_SECRET
ENCRYPTION_SALT=your-random-encryption-salt

# ─── Playwright (Sync Features) ─────────────────────────────────
# Set to skip browser download in environments that don't need sync
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
# Path to Chromium binary (if not using default Playwright-managed browser)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# ─── Client (Vite) ──────────────────────────────────────────────
# Set in client/.env.production
# VITE_API_URL=https://your-api-domain.com/api
