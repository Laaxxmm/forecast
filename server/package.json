{
  "name": "magna-tracker-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "echo 'Using tsx runtime'",
    "start": "npx tsx src/index.ts",
    "postinstall": "if [ -z \"$PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD\" ]; then npx playwright install --with-deps chromium || echo 'Playwright install failed, continuing...'; else echo 'Skipping Playwright browser download (PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD is set)'; fi"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "sql.js": "^1.11.0",
    "xlsx": "^0.18.5",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
